{
    "security.workspace.trust.enabled": false,
    "update.showReleaseNotes": false,
    "window.restoreWindows": "none",
    "extensions.autoUpdate": "onlyEnabledExtensions",
    // "extensions.ignoreRecommendations": true,
    "chat.commandCenter.enabled": false,
    "explorer.excludeGitIgnore": false,
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "files.autoGuessEncoding": true,
    "editor.formatOnType": true,
    "editor.formatOnSave": true,
    "editor.formatOnSaveMode": "file",
    "editor.codeActionsOnSave": {
        "source.organizeLinkDefinitions": "always",
        "source.organizeImports": "always",
        "source.fixAll": "always",
        "source.fixAll.sortJSON": "always",
        "source.fixAll.eslint": "always",
    },
    "editor.linkedEditing": true,
    "editor.fontLigatures": true,
    "editor.fontFamily": "'Cascadia Code', 'Jetbrains Mono', 'LXGW WenKai Mono', Menlo, Monaco, Consolas, 'Courier New', monospace",
    "terminal.integrated.fontFamily": "'Cascadia Mono NF', 'Jetbrains Mono NL', 'LXGW WenKai Mono', 'MesloLGS NF'",
    // "window.zoomLevel": 1,
    // "editor.fontSize": 13,
    // "editor.lineHeight": 22,
    // "editor.bracketPairColorization.enabled": false,
    "editor.rulers": [
        120
    ],
    "editor.cursorSmoothCaretAnimation": "on",
    "editor.cursorSurroundingLines": 5,
    "editor.smoothScrolling": true,
    "editor.stickyScroll.enabled": true,
    "editor.inlineSuggest.enabled": true,
    "editor.minimap.enabled": false,
    "editor.suggest.insertMode": "replace",
    "window.autoDetectColorScheme": true,
    "workbench.preferredDarkColorTheme": "Everforest Dark",
    "workbench.preferredLightColorTheme": "Default Light Modern",
    "workbench.iconTheme": "material-icon-theme",
    "workbench.startupEditor": "readme",
    "zenMode.hideLineNumbers": false,
    "zenMode.showTabs": "none",
    "window.customTitleBarVisibility": "windowed",
    "javascript.preferences.renameMatchingJsxTags": true,
    "typescript.preferences.renameMatchingJsxTags": true,
    "debug.allowBreakpointsEverywhere": true,
    "[shellscript]": {
        "files.eol": "\n",
        "editor.fontLigatures": false
    },
    "[bat]": {
        "files.eol": "\r\n",
        "editor.fontLigatures": false
    },
    "[markdown]": {
        "editor.quickSuggestions": {
            "comments": "on",
            "strings": "on",
            "other": "on"
        },
        "editor.defaultFormatter": "yzhang.markdown-all-in-one",
        "editor.formatOnSaveMode": "file"
    },
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "[csharp]": {
        "editor.defaultFormatter": "csharpier.csharpier-vscode"
    },
    "typescript.preferences.importModuleSpecifier": "relative",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "csv-edit.readOption_hasHeader": "true",
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "trailing-spaces.trimOnSave": true,
    "markdown-preview-enhanced.enableExtendedTableSyntax": false,
    "markdown-preview-enhanced.enableTypographer": true,
    "markdown-preview-enhanced.enableHTML5Embed": true,
    "markdown-preview-enhanced.HTML5EmbedUseLinkSyntax": true,
    "markdown-preview-enhanced.HTML5EmbedIsAllowedHttp": true,
    "markdown-preview-enhanced.enableCriticMarkupSyntax": true,
    "markdown-preview-enhanced.enablePreviewZenMode": true,
    "markdown-preview-enhanced.previewColorScheme": "editorColorScheme",
    // "markdown-preview-enhanced.puppeteerWaitForTimeout": 5000,
    // "markdown-preview-enhanced.chromePath": "C:\\Program Files (x86)\\Microsoft\\Edge\\Application\\msedge.exe",
    "telemetry.telemetryLevel": "all",
    "rest-client.enableTelemetry": false,
    "dotnet.enableTelemetry": false,
    "dotnet-test-explorer.enableTelemetry": false,
    "dotnetAcquisitionExtension.enableTelemetry": false,
    "dotnetAcquisitionExtension.installTimeoutValue": 0,
    "dotnetAcquisitionExtension.sharedExistingDotnetPath": "C:\\Program Files\\dotnet\\dotnet.exe",
    //"dotnetAcquisitionExtension.sharedExistingDotnetPath": "/usr/local/share/dotnet/dotnet",
    "dotnet.dotnetPath": "C:\\Program Files\\dotnet",
    // "dotnet.dotnetPath": "/usr/local/share/dotnet",
    "dotnet.preferCSharpExtension": true,
    "csharp.inlayHints.enableInlayHintsForImplicitObjectCreation": true,
    "csharp.inlayHints.enableInlayHintsForImplicitVariableTypes": true,
    "csharp.inlayHints.enableInlayHintsForLambdaParameterTypes": true,
    "csharp.inlayHints.enableInlayHintsForTypes": true,
    "dotnet.inlayHints.enableInlayHintsForIndexerParameters": true,
    "dotnet.inlayHints.enableInlayHintsForLiteralParameters": true,
    "dotnet.inlayHints.enableInlayHintsForObjectCreationParameters": true,
    "dotnet.inlayHints.enableInlayHintsForOtherParameters": true,
    "dotnet.inlayHints.enableInlayHintsForParameters": true,
    "dotnet.inlayHints.suppressInlayHintsForParametersThatDifferOnlyBySuffix": true,
    "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchArgumentName": true,
    "dotnet.inlayHints.suppressInlayHintsForParametersThatMatchMethodIntent": true,
    "coverage-gutters.showLineCoverage": true,
    "coverage-gutters.showRulerCoverage": true,
    "todo-tree.highlights.useColourScheme": true,
    "todo-tree.regex.regexCaseSensitive": false,
    "todo-tree.highlights.customHighlight": {
        "[ ]": {
            "background": "#ff000080"
        },
        "[x]": {
            "background": "#00ff0080"
        }
    },
    "numberedBookmarks.navigateThroughAllFiles": "replace",
    "easy-codesnap.showWindowControls": false,
    "hexeditor.showOpenFileButton": true,
    "clipboard-manager.preview": true,
    "clipboard-manager.snippet.enabled": false,
    "clock.dateFormat": "H:MM",
    "projectManager.sortList": "Recent",
    "sortJSON.contextMenu": {
        "sortJSON": false,
        "sortJSONAlphaNum": false,
        "sortJSONAlphaNumReverse": false,
        "sortJSONKeyLength": false,
        "sortJSONKeyLengthReverse": false,
        "sortJSONReverse": false,
        "sortJSONType": false,
        "sortJSONTypeReverse": false,
        "sortJSONValues": false,
        "sortJSONValuesReverse": false
    },
    "sortJSON.orderOverride": [
        "name",
        "version",
        "description"
    ],
    "sortJSON.orderUnderride": [
        "dependencies",
        "devDependencies"
    ],
